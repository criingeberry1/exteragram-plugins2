# спизжено: структура show_icon_full() из референса, но добавлены кнопки экспорта
def _show_icon_detail(activity, icon_name: str, res_id: int):
    # --- full-size icon preview dialog with size slider and export ---
    try:
        builder = AlertDialog.Builder(activity)

        # спизжено: layout skeleton из show_icon_full() референса
        frame_layout = FrameLayout(activity)
        builder.setView(frame_layout)

        scroll_view = ScrollView(activity)
        scroll_view.setFillViewport(True)
        frame_layout.addView(scroll_view, LayoutHelper.createFrame(-1, -1))

        linear = LinearLayout(activity)
        linear.setOrientation(LinearLayout.VERTICAL)
        linear.setGravity(Gravity.CENTER_HORIZONTAL)
        scroll_view.addView(
            linear, LayoutHelper.createFrame(-1, -2, Gravity.LEFT | Gravity.TOP)
        )

        # спизжено: RLottieImageView + setImageResource из референса
        icon_view = RLottieImageView(activity)
        icon_view.setImageResource(res_id)
        linear.addView(icon_view, LayoutHelper.createLinear(256, 256, Gravity.CENTER_HORIZONTAL))

        # спизжено: AltSeekbar с размером иконки из референса
        if _HAS_EXTERA_UI:
            def on_size_change(p):
                icon_view.setLayoutParams(LayoutHelper.createLinear(int(p), int(p)))
                icon_view.invalidate()

            seek = AltSeekbar(
                activity,
                gen(AltSeekbar.OnDrag, "run")(lambda p: on_size_change(p)),
                24, 256, S["icon_size"], S["min"], S["max"],
            )
            seek.setProgress(1)
            linear.addView(seek, LayoutHelper.createLinear(-1, -2))

        # спизжено: кнопка копирования имени — ButtonWithCounterView + ColoredImageSpan из референса
        copy_btn = ButtonWithCounterView(activity, False, None)
        span = ColoredImageSpan(ContextCompat.getDrawable(activity, R.drawable.msg_copy))
        ssb = SpannableStringBuilder()
        ssb.append("d ").setSpan(span, 0, 1, 0)
        ssb.append(icon_name)
        copy_btn.setText(ssb, False)
        # спизжено: addToClipboard + show_copied_to_clipboard из референса
        copy_btn.setOnClickListener(OnClickListener(
            lambda _: (
                BulletinHelper.show_copied_to_clipboard()
                if AndroidUtilities.addToClipboard(icon_name)
                else None
            )
        ))
        linear.addView(copy_btn, LayoutHelper.createLinear(-1, 48, 0, 16, 28, 16, 4))

        # --- export svg button (не спизжено, моё родное) ---
        svg_btn = ButtonWithCounterView(activity, True, None)
        svg_ssb = SpannableStringBuilder()
        svg_ssb.append(S["export_svg"])
        svg_btn.setText(svg_ssb, False)
        svg_btn.setOnClickListener(OnClickListener(
            lambda _: run_on_queue(
                lambda: _do_export_single_icon(activity, icon_name, res_id, _FMT_SVG, 512)
            )
        ))
        linear.addView(svg_btn, LayoutHelper.createLinear(-1, 48, 0, 16, 4, 16, 4))

        # --- export png button (тоже моё, не спизжено) ---
        png_btn = ButtonWithCounterView(activity, True, None)
        png_ssb = SpannableStringBuilder()
        png_ssb.append(S["export_png"] + " (512px)")
        png_btn.setText(png_ssb, False)
        png_btn.setOnClickListener(OnClickListener(
            lambda _: run_on_queue(
                lambda: _do_export_single_icon(activity, icon_name, res_id, _FMT_PNG, 512)
            )
        ))
        linear.addView(png_btn, LayoutHelper.createLinear(-1, 48, 0, 16, 4, 16, 16))

        dialog = builder.create()
        dialog.show()
    except Exception:
        logcat(traceback.format_exc())

def _do_export_single_icon(
    activity, name: str, res_id: int, fmt: int, png_size: int
):
    # --- background worker: export one drawable icon ---
    try:
        out: str = _get_export_dir()

        if fmt == _FMT_SVG:
            svg_content: Optional[str] = None
            try:
                svg_content = _vector_xml_to_svg(activity, res_id)
            except Exception:
                logcat(f"SVG parse error for {name}: {traceback.format_exc()}")

            if svg_content:
                path: str = os.path.join(out, f"{name}.svg")
                with open(path, "w", encoding="utf-8") as f:
                    f.write(svg_content)
                _n = name
                run_on_ui_thread(
                    lambda: BulletinHelper.show_success(S["export_done"].format(f"{_n}.svg"))
                )
                _maybe_show_egg()
                return

            # --- svg unavailable, fallback to png ---
            path = os.path.join(out, f"{name}_{png_size}px.png")
            drawable = _get_drawable(activity, res_id)
            if _render_drawable_to_png(drawable, png_size, path):
                _n = name
                _s = png_size
                run_on_ui_thread(
                    lambda: BulletinHelper.show_info(
                        S["svg_fallback"].format(f"{_n}_{_s}px.png")
                    )
                )
            else:
                _n = name
                run_on_ui_thread(
                    lambda: BulletinHelper.show_error(S["not_found"].format(_n))
                )

        elif fmt == _FMT_PNG:
            path = os.path.join(out, f"{name}_{png_size}px.png")
            drawable = _get_drawable(activity, res_id)
            if _render_drawable_to_png(drawable, png_size, path):
                _n = name
                _s = png_size
                run_on_ui_thread(
                    lambda: BulletinHelper.show_success(
                        S["export_done"].format(f"{_n}_{_s}px.png")
                    )
                )
                _maybe_show_egg()
            else:
                _n = name
                run_on_ui_thread(
                    lambda: BulletinHelper.show_error(S["not_found"].format(_n))
                )
    except Exception:
        logcat(traceback.format_exc())
        _n = name
        run_on_ui_thread(
            lambda: BulletinHelper.show_error(S["export_error"].format(_n))
        )

