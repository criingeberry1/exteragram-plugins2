import requests
import os
import traceback

# --- базовые инструменты разработчика ---
from base_plugin import BasePlugin, MethodReplacement, HookResult, HookStrategy
from hook_utils import find_class
from android_utils import log, run_on_ui_thread
from client_utils import run_on_queue, get_last_fragment
from ui.bulletin import BulletinHelper
from ui.alert import AlertDialogBuilder

# --- инструменты интерфейса ---
from ui.settings import Header, Input, Switch, Divider, Selector
from org.telegram.messenger import R as R_tg

# --- метаданные ---
__id__ = "whisper_transcribing"
__name__ = "Whisper Ai для распознавания речи"
__description__ = "Пока не придумала"
__author__ = "@insonniiia"
__version__ = "2.0.2"
__icon__ = "hsrgustinex/39"
__min_version__ = "11.12.0"


# --- универсальный обработчик для замены метода ---
class UniversalTranscribeReplacement(MethodReplacement):
    def __init__(self, plugin):
        self.plugin = plugin
        super(UniversalTranscribeReplacement, self).__init__()

    def replace_hooked_method(self, param):
        # --- если плагин выключен, выходим ---
        if not self.plugin.get_setting("groq_active", True):
            return None

        # --- ищем объект сообщения среди аргументов динамически ---
        # --- это защищает от изменений в разных версиях telegram ---
        msg_obj = None
        for arg in param.args:
            if arg and "MessageObject" in str(arg.getClass().getName()):
                msg_obj = arg
                break
        
        if msg_obj:
            # --- уведомление о перехвате (появится сразу) ---
            run_on_ui_thread(lambda: BulletinHelper.show_simple("Groq: Перехвачено!", R_tg.raw.lightning))
            # --- запускаем распознавание ---
            run_on_queue(lambda: self.plugin.execute_groq(msg_obj))
        else:
            log("groq_whisper: messageobject not found in args")
            run_on_ui_thread(lambda: BulletinHelper.show_error("Ошибка: сообщение не найдено в памяти"))
            
        return None

class GroqWhisperPlugin(BasePlugin):
    def __init__(self):
        super().__init__()

    def on_plugin_load(self):
        # --- блокировка сетевого трафика к серверам тг ---
        self.add_hook("TL_messages_transcribeAudio")
        
        # --- замена метода логики ---
        try:
            controller = find_class("org.telegram.messenger.MessagesController")
            if controller:
                # --- хукаем все вариации метода transcribeAudio ---
                self.hook_all_methods(controller, "transcribeAudio", UniversalTranscribeReplacement(self))
                log("groq_whisper: replacement hook installed")
        except:
            log(traceback.format_exc())

    def pre_request_hook(self, name, account, request):
        # --- пресекаем любые попытки отправить аудио в облако тг ---
        if name == "TL_messages_transcribeAudio":
            if self.get_setting("groq_active", True):
                log("groq_whisper: blocked native mtproto request")
                return HookResult(strategy=HookStrategy.CANCEL)
        return HookResult()

    def execute_groq(self, msg_obj):
        # --- настройки ---
        api_key = self.get_setting("gro_key", "")
        model_idx = self.get_setting("gro_model", 0)
        model_name = "whisper-large-v3" if model_idx == 0 else "distil-whisper-large-v3-en"
        
        if not api_key:
            run_on_ui_thread(lambda: BulletinHelper.show_error("Введи API Key в настройках!"))
            return

        try:
            # --- получаем путь к файлу ---
            document = msg_obj.getDocument()
            path = self._resolve_local_path(document)
            
            if not path or not os.path.exists(path):
                run_on_ui_thread(lambda: BulletinHelper.show_error("Файл не загружен. Прослушай его!"))
                return

            # --- подготовка данных для groq ---
            url = "https://api.groq.com/openai/v1/audio/transcriptions"
            headers = {"Authorization": f"Bearer {api_key}"}
            
            with open(path, "rb") as audio:
                files = {"file": (os.path.basename(path), audio, "audio/ogg")}
                data = {"model": model_name, "response_format": "json"}
                
                # --- сетевой запрос ---
                resp = requests.post(url, headers=headers, files=files, data=data, timeout=30)

            if resp.status_code == 200:
                text = resp.json().get("text", "Текст пуст.")
                run_on_ui_thread(lambda: self._display_result(text))
            else:
                log(f"groq_api_error: {resp.text}")
                run_on_ui_thread(lambda: BulletinHelper.show_error(f"Groq Error: {resp.status_code}"))

        except Exception as e:
            log(traceback.format_exc())
            run_on_ui_thread(lambda: BulletinHelper.show_error("Критическая ошибка плагина"))

    def _resolve_local_path(self, document):
        # --- используем fileloader для получения реального пути ---
        try:
            loader = find_class("org.telegram.messenger.FileLoader")
            # --- статический метод getPathToAttach ---
            method = loader.getClass().getMethod("getPathToAttach", [find_class("org.telegram.tgnet.TLObject"), bool])
            return str(method.invoke(None, [document, True]))
        except:
            return None

    def _display_result(self, text):
        # --- финальное окно с результатом ---
        activity = get_last_fragment().getParentActivity()
        if not activity: return

        builder = AlertDialogBuilder(activity)
        builder.set_title("Whisper (Groq Cloud)")
        builder.set_message(text)
        
        # --- кнопка копирования ---
        def copy_logic(b, w):
            from android.content import Context, ClipData
            mgr = activity.getSystemService(Context.CLIPBOARD_SERVICE)
            mgr.setPrimaryClip(ClipData.newPlainText("groq", text))
            BulletinHelper.show_success("Текст скопирован!")
            b.dismiss()

        builder.set_positive_button("Копировать", copy_logic)
        builder.set_negative_button("Ок", lambda b, w: b.dismiss())
        builder.show()

    def create_settings(self):
        # --- меню настроек плагина ---
        return [
            Header(text="Whisper Groq Cloud"),
            Switch(
                key="groq_active",
                text="Активен",
                default=True,
                subtext="Блокировать TG и использовать Groq"
            ),
            Divider(),
            Input(
                key="gro_key",
                text="API Key",
                default="",
                subtext="Вставь ключ с console.groq.com",
                icon="msg_permissions"
            ),
            Selector(
                key="gro_model",
                text="Модель",
                items=["Whisper Large V3 (Точно)", "Distil Whisper (Быстро)"],
                default=0,
                icon="msg_info"
            ),
            Divider(text="Надпись 'Не удалось распознать' - это норма, запрос в TG заблокирован.")
        ]
