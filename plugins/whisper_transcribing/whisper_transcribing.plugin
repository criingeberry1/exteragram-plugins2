import requests
import os
import traceback
from typing import Any, List, Dict, Optional

# --- импорт базовых системных компонентов ---
from base_plugin import BasePlugin, MethodReplacement, MethodHook, HookResult, HookStrategy
from hook_utils import find_class, set_private_field
from android_utils import log, run_on_ui_thread
from client_utils import run_on_queue, get_last_fragment
from ui.bulletin import BulletinHelper

# --- компоненты интерфейса ---
from ui.settings import Header, Input, Switch, Divider, Selector
from org.telegram.messenger import R as R_tg

# --- метаданные ---
__id__ = "whisper_transcribing"
__name__ = "Whisper Ai для распознавания речи"
__description__ = "Пока не придумала"
__author__ = "@insonniiia"
__version__ = "3.0.0"
__icon__ = "hsrgustinex/39"
__min_version__ = "11.12.0"


# --- глобальный кэш для хранения транскрипций в рамках сессии ---
transcription_cache: Dict[str, str] = {}

# --- хук для внедрения текста в ячейку чата ---
class MessageContentHook(MethodHook):
    def __init__(self, plugin: 'GroqWhisperPlugin'):
        self.plugin = plugin
        super(MessageContentHook, self).__init__()

    def before_hooked_method(self, param: Any):
        # --- аргумент 0 это messageobject ---
        try:
            message_object = param.args[0]
            if not message_object:
                return

            # --- формируем уникальный ключ сообщения ---
            msg_key = f"{message_object.getId()}_{message_object.getDialogId()}"
            
            # --- если в кэше есть текст для этого сообщения ---
            if msg_key in transcription_cache:
                new_text = transcription_cache[msg_key]
                
                # --- подменяем текст в объекте ---
                if hasattr(message_object, "caption") and message_object.caption is not None:
                    message_object.caption = new_text
                    set_private_field(message_object, "captionLayout", None)
                else:
                    try:
                        message_object.applyNewText(new_text)
                    except:
                        message_object.messageText = new_text
                    set_private_field(message_object, "textLayout", None)
        except:
            pass

# --- замена метода запуска транскрибации ---
class TranscribeReplacement(MethodReplacement):
    def __init__(self, plugin: 'GroqWhisperPlugin'):
        self.plugin = plugin
        super(TranscribeReplacement, self).__init__()

    def replace_hooked_method(self, param: Any):
        # --- полностью блокируем натив и запускаем свою логику ---
        try:
            msg_obj = None
            for arg in param.args:
                if arg and "MessageObject" in str(arg.getClass().getName()):
                    msg_obj = arg
                    break
            
            if msg_obj:
                run_on_queue(lambda: self.plugin.process_whisper_locally(msg_obj))
        except:
            log(traceback.format_exc())
        return None

class GroqWhisperPlugin(BasePlugin):
    def __init__(self):
        super().__init__()
        self.unhooks: List[Any] = []

    def on_plugin_load(self):
        # --- блокируем сетевой запрос тг ---
        self.add_hook("TL_messages_transcribeAudio")
        
        try:
            # --- 1. заменяем логику нажатия кнопки ---
            controller = find_class("org.telegram.messenger.MessagesController")
            if controller:
                self.hook_all_methods(controller, "transcribeAudio", TranscribeReplacement(self))
            
            # --- 2. хукаем отрисовку ячейки сообщения ---
            cell_class = find_class("org.telegram.ui.Cells.ChatMessageCell")
            if cell_class:
                # --- ищем метод setmessagecontent через рефлексию ---
                for method in cell_class.getClass().getDeclaredMethods():
                    if method.getName() == "setMessageContent":
                        self.unhooks.append(self.hook_method(method, MessageContentHook(self)))
            
            log("groq_local: all hooks installed")
        except:
            log(traceback.format_exc())

    def pre_request_hook(self, name: str, account: int, request: Any) -> HookResult:
        # --- отменяем нативный запрос к серверам ---
        if name == "TL_messages_transcribeAudio":
            return HookResult(strategy=HookStrategy.CANCEL)
        return HookResult()

    def process_whisper_locally(self, msg_obj: Any):
        api_key = self.get_setting("gro_key", "")
        if not api_key:
            run_on_ui_thread(lambda: BulletinHelper.show_error("Нужен Groq API Key!"))
            return

        run_on_ui_thread(lambda: BulletinHelper.show_simple("Whisper: Обработка...", R_tg.raw.transcribe))

        try:
            # --- получение пути к файлу ---
            doc = msg_obj.getDocument()
            path = self._get_path(doc)
            
            if not path or not os.path.exists(path):
                run_on_ui_thread(lambda: BulletinHelper.show_error("Сначала скачай аудио!"))
                return

            # --- запрос к groq ---
            headers = {"Authorization": f"Bearer {api_key}"}
            with open(path, "rb") as f:
                files = {"file": (os.path.basename(path), f, "audio/ogg")}
                data = {"model": "whisper-large-v3"}
                resp = requests.post("https://api.groq.com/openai/v1/audio/transcriptions", headers=headers, files=files, data=data, timeout=30)

            if resp.status_code == 200:
                text = resp.json().get("text", "")
                msg_key = f"{msg_obj.getId()}_{msg_obj.getDialogId()}"
                
                # --- сохраняем в кэш и форсируем обновление ---
                transcription_cache[msg_key] = "[Whisper]: " + text
                run_on_ui_thread(lambda: self._force_update_cell(msg_obj))
            else:
                run_on_ui_thread(lambda: BulletinHelper.show_error(f"API Error: {resp.status_code}"))

        except:
            log(traceback.format_exc())

    def _get_path(self, document: Any) -> Optional[str]:
        try:
            loader = find_class("org.telegram.messenger.FileLoader")
            method = loader.getClass().getMethod("getPathToAttach", [find_class("org.telegram.tgnet.TLObject"), bool])
            return str(method.invoke(None, [document, True]))
        except:
            return None

    def _force_update_cell(self, msg_obj: Any):
        # --- заставляем список чата перерисовать конкретное сообщение ---
        try:
            fragment = get_last_fragment()
            if not fragment: return
            
            list_view = fragment.getChatListView()
            if not list_view: return
            
            adapter = list_view.getAdapter()
            if not adapter: return

            # --- ищем позицию сообщения в адаптере ---
            msg_id = msg_obj.getId()
            for i in range(adapter.getItemCount()):
                item = adapter.getItem(i)
                if item and hasattr(item, "getId") and item.getId() == msg_id:
                    adapter.notifyItemChanged(i)
                    break
            
            BulletinHelper.show_success("Готово!")
        except:
            pass

    def create_settings(self) -> List[Any]:
        return [
            Header(text="Whisper Local Injector"),
            Input(key="gro_key", text="Groq API Key", default="", icon="msg_permissions"),
            Divider(),
            Header(text="Результат будет вписан прямо в текст сообщения локально.")
        ]
