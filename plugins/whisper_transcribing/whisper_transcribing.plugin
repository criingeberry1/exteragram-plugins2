import os
import requests
from typing import Dict, Any, List

from base_plugin import BasePlugin, MenuItemData, MenuItemType
from hook_utils import find_class
from android_utils import run_on_ui_thread
from client_utils import run_on_queue, send_message
from ui.settings import Header, Input
from ui.bulletin import BulletinHelper
from ui.alert import AlertDialogBuilder
from markdown_utils import parse_markdown

# --- метаданные ---
__id__ = "whisper_transcribing"
__name__ = "Whisper Ai для распознавания речи"
__description__ = "Пока не придумала"
__author__ = "@insonniiia"
__version__ = "4.0.0"
__icon__ = "hsrgustinex/39"
__min_version__ = "11.12.0"


class WhisperTranscriptionPlugin(BasePlugin):
    def on_plugin_load(self):
        # --- registering context menu item for audio messages ---
        self.add_menu_item(
            MenuItemData(
                menu_type=MenuItemType.MESSAGE_CONTEXT_MENU,
                text="Transcribe Audio",
                on_click=self._handle_transcription_click,
                icon="msg_translate",
                condition="message.isVoice() || message.isMusic()"
            )
        )

    def create_settings(self) -> List[Any]:
        # --- generating settings screen for api configuration ---
        return [
            Header(text="groq api configuration"),
            Input(
                key="groq_api_key",
                text="groq api key",
                default="",
                subtext="required for whisper transcription (console.groq.com)",
                icon="msg_settings"
            )
        ]

    def _handle_transcription_click(self, context: Dict[str, Any]):
        # --- retrieving context variables ---
        message = context.get("message")
        dialog_id = context.get("dialog_id")
        fragment = context.get("fragment")

        # --- validating required dependencies ---
        if not message or not dialog_id or not fragment:
            return

        api_key = self.get_setting("groq_api_key", "")
        if not api_key:
            BulletinHelper.show_error("groq api key is missing in settings", fragment)
            return

        activity = fragment.getParentActivity()
        if not activity:
            return

        # --- displaying blocking loading spinner on ui thread ---
        progress_dialog = AlertDialogBuilder(activity, AlertDialogBuilder.ALERT_TYPE_SPINNER)
        progress_dialog.set_title("Transcribing audio...")
        progress_dialog.set_cancelable(False)
        progress_dialog.show()

        # --- offloading heavy network task to background queue ---
        run_on_queue(lambda: self._process_transcription(message, dialog_id, api_key, progress_dialog, fragment))

    def _process_transcription(self, message: Any, dialog_id: int, api_key: str, dialog: AlertDialogBuilder, fragment: Any):
        # --- resolving file loader class via reflection ---
        file_loader_class = find_class("org.telegram.messenger.FileLoader")
        if not file_loader_class:
            self._cleanup_with_error(dialog, fragment, "internal error finding file loader")
            return

        # --- retrieving local file path from telegram cache ---
        try:
            account = message.currentAccount
            file_loader_instance = file_loader_class.getInstance(account)
            file_obj = file_loader_instance.getPathToMessage(message.messageOwner)

            if not file_obj or not file_obj.exists():
                self._cleanup_with_error(dialog, fragment, "audio file is not downloaded locally")
                return

            file_path = file_obj.getAbsolutePath()
        except Exception as e:
            self._cleanup_with_error(dialog, fragment, f"failed to locate local file: {str(e)}")
            return

        # --- executing groq api request ---
        url = "https://api.groq.com/openai/v1/audio/transcriptions"
        headers = {"Authorization": f"Bearer {api_key}"}
        
        try:
            with open(file_path, "rb") as f:
                files = {"file": (os.path.basename(file_path), f)}
                data = {"model": "whisper-large-v3"}
                response = requests.post(url, headers=headers, files=files, data=data, timeout=120)
        except Exception as e:
            self._cleanup_with_error(dialog, fragment, f"network execution error: {str(e)}")
            return

        # --- validating rest api response state ---
        if response.status_code != 200:
            self._cleanup_with_error(dialog, fragment, f"groq api rejected request: {response.status_code}")
            return

        try:
            response_data = response.json()
            transcribed_text = response_data.get("text", "").strip()
        except Exception as e:
            self._cleanup_with_error(dialog, fragment, f"json parsing fault: {str(e)}")
            return

        if not transcribed_text:
            self._cleanup_with_error(dialog, fragment, "no speech detected in audio")
            return

        # --- passing result to dispatcher ---
        self._send_transcription(dialog_id, message.getId(), transcribed_text, dialog, fragment)

    def _send_transcription(self, dialog_id: int, msg_id: int, text: str, dialog: AlertDialogBuilder, fragment: Any):
        # --- structuring output message with standard markdown ---
        formatted_text = f"**Transcription:**\n{text}"
        
        try:
            parsed_message = parse_markdown(formatted_text)
            params = {
                "peer": dialog_id,
                "reply_to_msg_id": msg_id,
                "message": parsed_message.text,
                "entities": [entity.to_tlrpc_object() for entity in parsed_message.entities]
            }
        except Exception as e:
            self._cleanup_with_error(dialog, fragment, f"markdown entity compilation failed: {str(e)}")
            return

        # --- synchronizing with main thread to dispatch message and dismiss dialog ---
        def _finalize():
            try:
                dialog.dismiss()
                send_message(params)
                BulletinHelper.show_success("Transcription dispatched", fragment)
            except Exception as e:
                BulletinHelper.show_error(f"failed to send reply: {str(e)}", fragment)

        run_on_ui_thread(_finalize)

    def _cleanup_with_error(self, dialog: AlertDialogBuilder, fragment: Any, error_msg: str):
        # --- tearing down ui state gracefully on exception ---
        def _teardown():
            try:
                dialog.dismiss()
                BulletinHelper.show_error(error_msg, fragment)
            except Exception:
                pass
        run_on_ui_thread(_teardown)
