import requests
import os
from typing import Any, List, Optional

from base_plugin import BasePlugin, MethodHook, hook_filters, HookFilter
from hook_utils import find_class
from android_utils import log, run_on_ui_thread
from client_utils import run_on_queue, get_last_fragment
from ui.bulletin import BulletinHelper
from ui.alert import AlertDialogBuilder
from ui.settings import Header, Input, Switch, Divider, Selector
from org.telegram.messenger import R as R_tg

# --- метаданные ---
__id__ = "whisper_transcribing"
__name__ = "Whisper Ai для распознавания речи"
__description__ = "Пока не придумала"
__author__ = "@insonniiia"
__version__ = "1.1.0"
__icon__ = "hsrgustinex/39"
__min_version__ = "11.12.0"


# --- hook handler for transcription button ---
class GroqTranscribeHook(MethodHook):
    def __init__(self, plugin: 'GroqWhisperPlugin'):
        self.plugin = plugin

    def before_hooked_method(self, param: Any):
        # --- args: [long dialog_id, MessageObject message_object] ---
        message_object = param.args[1]
        
        # --- check if plugin is enabled ---
        if not self.plugin.get_setting("groq_enabled", True):
            return

        # --- cancel native telegram transcription ---
        param.setResult(None)
        
        # --- run background processing ---
        run_on_queue(lambda: self.plugin.process_groq_transcription(message_object))

class GroqWhisperPlugin(BasePlugin):
    def on_plugin_load(self):
        # --- find necessary java classes ---
        messages_controller_class = find_class("org.telegram.messenger.MessagesController")
        message_object_class = find_class("org.telegram.messenger.MessageObject")
        
        if not messages_controller_class or not message_object_class:
            log("groq_whisper: core classes not found")
            return

        try:
            # --- hook transcribeAudio method ---
            # --- using reflection to get the method with long and messageobject params ---
            long_class = find_class("java.lang.Long").getField("TYPE").get(None)
            target_method = messages_controller_class.getClass().getDeclaredMethod(
                "transcribeAudio", 
                long_class, 
                message_object_class
            )
            
            self.hook_method(target_method, GroqTranscribeHook(self))
            log("groq_whisper: hooked successfully")
        except Exception as e:
            log(f"groq_whisper: hook error: {str(e)}")

    def process_groq_transcription(self, message_object: Any):
        # --- get configuration from settings ---
        api_key = self.get_setting("groq_api_key", "")
        model = self.get_setting("groq_model_name", "whisper-large-v3")
        endpoint = "https://api.groq.com/openai/v1/audio/transcriptions"

        if not api_key:
            run_on_ui_thread(lambda: BulletinHelper.show_error("Groq API Key не указан!"))
            return

        # --- indicate that plugin is working (non-native feel) ---
        run_on_ui_thread(lambda: BulletinHelper.show_simple(
            "Groq AI: Обработка аудио...", 
            R_tg.raw.lightning # --- lightning icon for speed indication ---
        ))

        try:
            # --- get file path from telegram storage ---
            document = message_object.getDocument()
            file_path = self._get_local_path(document)
            
            if not file_path or not os.path.exists(file_path):
                run_on_ui_thread(lambda: BulletinHelper.show_error("Файл не скачан или не найден."))
                return

            # --- prepare multipart request ---
            headers = {"Authorization": f"Bearer {api_key}"}
            files = {"file": (os.path.basename(file_path), open(file_path, "rb"), "audio/ogg")}
            data = {"model": model, "response_format": "json"}

            # --- api call ---
            response = requests.post(endpoint, headers=headers, files=files, data=data, timeout=25)
            
            if response.status_code == 200:
                result_text = response.json().get("text", "")
                # --- show result in a dedicated dialog ---
                run_on_ui_thread(lambda: self._show_result_dialog(result_text))
            else:
                log(f"groq_error: {response.text}")
                run_on_ui_thread(lambda: BulletinHelper.show_error(f"Groq API Error: {response.status_code}"))

        except Exception as e:
            log(f"groq_whisper: critical error: {str(e)}")
            run_on_ui_thread(lambda: BulletinHelper.show_error("Ошибка плагина Groq"))

    def _get_local_path(self, document: Any) -> Optional[str]:
        # --- internal method to resolve telegram file path ---
        try:
            file_loader = find_class("org.telegram.messenger.FileLoader")
            method = file_loader.getClass().getMethod("getPathToAttach", find_class("org.telegram.tgnet.TLObject"), bool)
            java_file = method.invoke(None, document, True)
            return java_file.toString()
        except:
            return None

    def _show_result_dialog(self, text: str):
        # --- using alertdialogbuilder to make it obvious it's a plugin result ---
        activity = get_last_fragment().getParentActivity()
        if not activity:
            return

        builder = AlertDialogBuilder(activity)
        builder.set_title("Groq Whisper (Plugin)")
        builder.set_message(text)
        
        # --- button to copy text ---
        def on_copy(b, w):
            self._copy_to_clipboard(text)
            b.dismiss()

        builder.set_positive_button("Копировать", on_copy)
        builder.set_negative_button("Закрыть", lambda b, w: b.dismiss())
        builder.show()

    def _copy_to_clipboard(self, text: str):
        # --- utility for clipboard ---
        try:
            from android.content import Context, ClipData
            activity = get_last_fragment().getParentActivity()
            clipboard = activity.getSystemService(Context.CLIPBOARD_SERVICE)
            clip = ClipData.newPlainText("Groq", text)
            clipboard.setPrimaryClip(clip)
            BulletinHelper.show_success("Текст скопирован")
        except:
            pass

    def create_settings(self) -> List[Any]:
        return [
            Header(text="Настройки Groq Cloud"),
            Switch(
                key="groq_enabled",
                text="Использовать Groq для расшифровки",
                default=True,
                subtext="Заменяет нативную расшифровку на Groq Whisper"
            ),
            Divider(),
            Input(
                key="groq_api_key",
                text="API Key",
                default="",
                subtext="Ключ из console.groq.com",
                icon="msg_permissions"
            ),
            Selector(
                key="groq_model_name",
                text="Модель Whisper",
                items=["whisper-large-v3", "distil-whisper-large-v3-en"],
                default=0,
                subtext="Large — точнее, Distil — быстрее"
            ),
            Divider(text="Информация"),
            Header(text="Плагин перехватывает нажатие кнопки расшифровки и выводит результат в отдельное окно.")
        ]
