import requests
import os
import traceback

# --- импорт системных библиотек ---
from base_plugin import BasePlugin, MethodHook
from hook_utils import find_class
from android_utils import log, run_on_ui_thread
from client_utils import run_on_queue, get_last_fragment
from ui.bulletin import BulletinHelper
from ui.alert import AlertDialogBuilder

# --- компоненты интерфейса ---
from ui.settings import Header, Input, Switch, Divider, Selector
from org.telegram.messenger import R as R_tg

# --- метаданные ---
__id__ = "whisper_transcribing"
__name__ = "Whisper Ai для распознавания речи"
__description__ = "Пока не придумала"
__author__ = "@insonniiia"
__version__ = "1.2.0"
__icon__ = "hsrgustinex/39"
__min_version__ = "11.12.0"


# --- обработчик хука groq ---
class GroqTranscribeHook(MethodHook):
    def __init__(self, plugin):
        self.plugin = plugin
        super(GroqTranscribeHook, self).__init__()

    def before_hooked_method(self, param):
        # --- если плагин выключен в настройках ---
        if not self.plugin.get_setting("groq_enabled", True):
            return

        # --- param.args[1] это messageobject ---
        try:
            message_object = param.args[1]
            
            # --- отменяем нативную расшифровку ---
            param.setResult(None)
            
            # --- уходим в фон ---
            run_on_queue(lambda: self.plugin.run_whisper(message_object))
        except:
            log(traceback.format_exc())

class GroqWhisperPlugin(BasePlugin):
    def __init__(self):
        # --- обязательный вызов конструктора базы ---
        super().__init__()

    def on_plugin_load(self):
        # --- регистрация через hook_all_methods самая стабильная ---
        try:
            controller = find_class("org.telegram.messenger.MessagesController")
            if controller:
                self.hook_all_methods(controller, "transcribeAudio", GroqTranscribeHook(self))
                log("groq_whisper: hook success")
        except:
            log(traceback.format_exc())

    def run_whisper(self, message_object):
        # --- получение настроек ---
        api_key = self.get_setting("gro_key", "")
        model = ["whisper-large-v3", "distil-whisper-large-v3-en"][self.get_setting("gro_model", 0)]
        
        if not api_key:
            run_on_ui_thread(lambda: BulletinHelper.show_error("API Key не найден!"))
            return

        # --- уведомление о старте ---
        run_on_ui_thread(lambda: BulletinHelper.show_simple("Groq: Начинаю...", R_tg.raw.lightning))

        try:
            # --- получаем путь к файлу ---
            doc = message_object.getDocument()
            path = self._resolve_path(doc)
            
            if not path or not os.path.exists(path):
                run_on_ui_thread(lambda: BulletinHelper.show_error("Сначала скачай аудио!"))
                return

            # --- запрос к groq cloud ---
            url = "https://api.groq.com/openai/v1/audio/transcriptions"
            headers = {"Authorization": "Bearer " + api_key}
            
            with open(path, "rb") as audio_file:
                files = {"file": (os.path.basename(path), audio_file, "audio/ogg")}
                data = {"model": model}
                resp = requests.post(url, headers=headers, files=files, data=data, timeout=30)

            if resp.status_code == 200:
                result = resp.json().get("text", "Текст пуст")
                run_on_ui_thread(lambda: self._show_dialog(result))
            else:
                run_on_ui_thread(lambda: BulletinHelper.show_error("Ошибка API: " + str(resp.status_code)))

        except Exception as e:
            log(traceback.format_exc())
            run_on_ui_thread(lambda: BulletinHelper.show_error("Ошибка плагина"))

    def _resolve_path(self, document):
        # --- достаем путь через загрузчик телеграма ---
        try:
            loader = find_class("org.telegram.messenger.FileLoader")
            method = loader.getClass().getMethod("getPathToAttach", [find_class("org.telegram.tgnet.TLObject"), bool])
            return str(method.invoke(None, [document, True]))
        except:
            return None

    def _show_dialog(self, text):
        # --- вывод через alertdialogbuilder для отличия от натива ---
        act = get_last_fragment().getParentActivity()
        if not act: return

        builder = AlertDialogBuilder(act)
        builder.set_title("Groq Whisper")
        builder.set_message(text)
        
        def copy_text(b, w):
            from android.content import Context, ClipData
            clipboard = act.getSystemService(Context.CLIPBOARD_SERVICE)
            clip = ClipData.newPlainText("whisper", text)
            clipboard.setPrimaryClip(clip)
            BulletinHelper.show_success("Скопировано")
            b.dismiss()

        builder.set_positive_button("Копировать", copy_text)
        builder.set_negative_button("Закрыть", lambda b, w: b.dismiss())
        builder.show()

    # --- метод настроек без аннотаций типов для стабильности ---
    def create_settings(self):
        return [
            Header(text="Настройки Groq"),
            Switch(
                key="groq_enabled",
                text="Активен",
                default=True,
                subtext="Заменяет нативную расшифровку"
            ),
            Divider(),
            Input(
                key="gro_key",
                text="API Key",
                default="",
                subtext="Вставь ключ от Groq Cloud",
                icon="msg_permissions"
            ),
            Selector(
                key="gro_model",
                text="Модель",
                items=["Large V3 (точность)", "Distil (скорость)"],
                default=0,
                icon="msg_info"
            ),
            Divider(text="Результат появится в отдельном окне.")
        ]
