import requests
import os
from typing import Any, List, Optional

# --- основные инструменты движка ---
from base_plugin import BasePlugin, MethodHook
from hook_utils import find_class
from android_utils import log, run_on_ui_thread
from client_utils import run_on_queue, get_last_fragment
from ui.bulletin import BulletinHelper
from ui.alert import AlertDialogBuilder

# --- компоненты настроек (импортируем всё необходимое для интерфейса) ---
from ui.settings import Header, Input, Switch, Divider, Selector
from org.telegram.messenger import R as R_tg

# --- метаданные ---
__id__ = "whisper_transcribing"
__name__ = "Whisper Ai для распознавания речи"
__description__ = "Пока не придумала"
__author__ = "@insonniiia"
__version__ = "1.1.1"
__icon__ = "hsrgustinex/39"
__min_version__ = "11.12.0"


# --- обработчик хука для перехвата кнопки расшифровки ---
class GroqTranscribeHook(MethodHook):
    def __init__(self, plugin: 'GroqWhisperPlugin'):
        self.plugin = plugin

    def before_hooked_method(self, param: Any):
        # --- аргументы: [long dialog_id, MessageObject message_object] ---
        # --- берем второй аргумент (индекс 1), это сам объект сообщения ---
        message_object = param.args[1]
        
        # --- если плагин выключен в его собственных настройках, ничего не делаем ---
        if not self.plugin.get_setting("groq_enabled", True):
            return

        # --- блокируем стандартную расшифровку телеграма ---
        # --- это предотвращает отправку аудио на серверы TG ---
        param.setResult(None)
        
        # --- запускаем нашу обработку в фоновом потоке ---
        run_on_queue(lambda: self.plugin.process_groq_transcription(message_object))

class GroqWhisperPlugin(BasePlugin):
    def on_plugin_load(self):
        # --- ищем класс контроллера сообщений ---
        messages_controller_class = find_class("org.telegram.messenger.MessagesController")
        
        if not messages_controller_class:
            log("groq_whisper: messagescontroller class not found")
            return

        try:
            # --- используем hook_all_methods, чтобы не возиться с типами аргументов java ---
            # --- это самый надежный способ «попасть» в метод transcribeAudio ---
            self.hook_all_methods(
                messages_controller_class, 
                "transcribeAudio", 
                GroqTranscribeHook(self)
            )
            log("groq_whisper: hook applied successfully to all transcribeAudio methods")
        except Exception as e:
            log(f"groq_whisper: loading error: {str(e)}")

    def process_groq_transcription(self, message_object: Any):
        # --- тянем настройки, которые ты укажешь в меню (когда оно появится) ---
        api_key = self.get_setting("groq_api_key", "")
        model = self.get_setting("groq_model_name", "whisper-large-v3")
        endpoint = "https://api.groq.com/openai/v1/audio/transcriptions"

        if not api_key:
            run_on_ui_thread(lambda: BulletinHelper.show_error("Введи Groq API Key в настройках!"))
            return

        # --- показываем, что плагин начал работу (визуальный отклик) ---
        run_on_ui_thread(lambda: BulletinHelper.show_simple(
            "Groq AI: Транскрибация...", 
            R_tg.raw.lightning
        ))

        try:
            # --- достаем путь к файлу из сообщения ---
            document = message_object.getDocument()
            file_path = self._get_local_path(document)
            
            if not file_path or not os.path.exists(file_path):
                run_on_ui_thread(lambda: BulletinHelper.show_error("Аудио еще не скачано. Прослушай его сначала."))
                return

            # --- готовим запрос к groq cloud ---
            headers = {"Authorization": f"Bearer {api_key}"}
            # --- читаем файл ---
            with open(file_path, "rb") as f:
                files = {"file": (os.path.basename(file_path), f, "audio/ogg")}
                data = {"model": model, "response_format": "json"}

                # --- отправляем ---
                response = requests.post(endpoint, headers=headers, files=files, data=data, timeout=30)
            
            if response.status_code == 200:
                text = response.json().get("text", "Пустой результат.")
                # --- выводим результат в диалог ---
                run_on_ui_thread(lambda: self._show_result_dialog(text))
            else:
                run_on_ui_thread(lambda: BulletinHelper.show_error(f"Groq Error: {response.status_code}"))

        except Exception as e:
            log(f"groq_whisper: processing error: {str(e)}")
            run_on_ui_thread(lambda: BulletinHelper.show_error("Ошибка при запросе к Whisper"))

    def _get_local_path(self, document: Any) -> Optional[str]:
        # --- магия получения пути к файлу через внутренний загрузчик телеги ---
        try:
            file_loader = find_class("org.telegram.messenger.FileLoader")
            # --- вызываем статический метод getPathToAttach ---
            method = file_loader.getClass().getMethod("getPathToAttach", [find_class("org.telegram.tgnet.TLObject"), bool])
            java_file = method.invoke(None, [document, True])
            return str(java_file)
        except:
            return None

    def _show_result_dialog(self, text: str):
        # --- создаем окно с результатом (AlertDialogBuilder) ---
        activity = get_last_fragment().getParentActivity()
        if not activity:
            return

        builder = AlertDialogBuilder(activity)
        builder.set_title("Whisper (Groq Cloud)")
        builder.set_message(text)
        
        # --- добавляем кнопку копирования для удобства ---
        builder.set_positive_button("Скопировать", lambda b, w: self._copy_and_close(text, b))
        builder.set_negative_button("Закрыть", lambda b, w: b.dismiss())
        builder.show()

    def _copy_and_close(self, text: str, builder: Any):
        try:
            from android.content import Context, ClipData
            activity = get_last_fragment().getParentActivity()
            clipboard = activity.getSystemService(Context.CLIPBOARD_SERVICE)
            clip = ClipData.newPlainText("Whisper", text)
            clipboard.setPrimaryClip(clip)
            BulletinHelper.show_success("Текст скопирован")
        except:
            pass
        builder.dismiss()

    # --- ВОТ ЭТОТ МЕТОД РИСУЕТ ШЕСТЕРЕНКУ В МЕНЮ ПЛАГИНОВ ---
    def create_settings(self) -> List[Any]:
        return [
            Header(text="Whisper via Groq Cloud"),
            Switch(
                key="groq_enabled",
                text="Включить замену",
                default=True,
                subtext="Использовать Groq вместо нативной расшифровки"
            ),
            Divider(),
            Input(
                key="groq_api_key",
                text="Groq API Key",
                default="",
                subtext="Вставь свой ключ с console.groq.com",
                icon="msg_permissions"
            ),
            Selector(
                key="groq_model_name",
                text="Выбор модели",
                items=["whisper-large-v3", "distil-whisper-large-v3-en"],
                default=0,
                subtext="Large — лучше для русского, Distil — быстрее"
            ),
            Divider(text="Настройки плагина подтянутся после правильной загрузки кода.")
        ]
