        egg: str = random.choice(_EASTER_EGGS)
        run_on_ui_thread(lambda: BulletinHelper.show_info(egg))

# ===========================================================================
# спизжено: dynamic proxy factory — целиком утащено из референса DevSettingIcons
# ===========================================================================

def gen(java_class, method_name: str, return_value: bool = False, default_value=None):
    # спизжено: gen() один-в-один из референса, только тег ошибки поменял
    def _run(instance, *java_args):
        try:
            value = instance._fn(*java_args, *instance._args, **instance._kwargs)
            if return_value:
                return value
        except Exception:
            logcat("[ERROR] [IconExporter] " + traceback.format_exc())
            return default_value

    def __init__(self, fn, *args, **kwargs):
        self._fn = fn
        self._args = args
        self._kwargs = kwargs
        super(type(self), self).__init__()

    proxy_cls = type(
        "Proxy_" + java_class.__name__,
        (dynamic_proxy(java_class),),
        {"__init__": __init__, method_name: _run},
    )
    return proxy_cls

# спизжено: все четыре proxy-конструктора из референса
Callback2 = gen(Utilities.Callback2, "run")
Callback5 = gen(Utilities.Callback5, "run")
OnClickListener = gen(View.OnClickListener, "onClick")
OnDismissListener = gen(DialogInterface.OnDismissListener, "onDismiss")

# ===========================================================================
#  svg conversion: vectordrawable compiled xml -> svg markup
# ===========================================================================

def _xml_attr(parser, name: str) -> Optional[str]:
    # --- read attribute value, stripping android dimension suffixes ---
    val = parser.getAttributeValue(_ANDROID_NS, name)
    if val is None:
        return None
    return str(val).replace("dp", "").replace("sp", "").replace("px", "")

def _xml_color_attr(parser, name: str) -> Optional[str]:
    # --- read color attribute as hex string ---
    sv = parser.getAttributeValue(_ANDROID_NS, name)
    if sv is not None and str(sv).startswith("#"):
        return str(sv)
    try:
        sentinel: int = 0x01FFFFFF
        iv: int = parser.getAttributeIntValue(_ANDROID_NS, name, sentinel)
        if iv != sentinel:
            r: int = (iv >> 16) & 0xFF
            g: int = (iv >> 8) & 0xFF
            b: int = iv & 0xFF
            return f"#{r:02x}{g:02x}{b:02x}"
    except Exception:
        pass
    return None

def _build_path_attrs(parser) -> str:
    # --- collect all svg-relevant attributes from a vector path element ---
    pd: str = _xml_attr(parser, "pathData") or ""
    fc: Optional[str] = _xml_color_attr(parser, "fillColor")
    sc: Optional[str] = _xml_color_attr(parser, "strokeColor")
    sw: Optional[str] = _xml_attr(parser, "strokeWidth")
    fa: Optional[str] = _xml_attr(parser, "fillAlpha")
    sa: Optional[str] = _xml_attr(parser, "strokeAlpha")
    ft: Optional[str] = _xml_attr(parser, "fillType")
    lc: Optional[str] = _xml_attr(parser, "strokeLineCap")
    lj: Optional[str] = _xml_attr(parser, "strokeLineJoin")

    parts: List[str] = [f'd="{pd}"']

    if fc:
        parts.append(f'fill="{fc}"')
    elif sc:
        parts.append('fill="none"')
    else:
        parts.append('fill="#000000"')

    if fa and fa != "1":
        parts.append(f'fill-opacity="{fa}"')
    if sc:
        parts.append(f'stroke="{sc}"')
    if sw:
        parts.append(f'stroke-width="{sw}"')
    if sa and sa != "1":
        parts.append(f'stroke-opacity="{sa}"')
    if ft and "evenodd" in str(ft).lower():
        parts.append('fill-rule="evenodd"')
    if lc:
        parts.append(f'stroke-linecap="{str(lc).lower()}"')
    if lj:
        parts.append(f'stroke-linejoin="{str(lj).lower()}"')

    return " ".join(parts)

def _build_group_transform(parser) -> str:
    # --- construct svg transform from android group properties ---
    transforms: List[str] = []
    tx: Optional[str] = _xml_attr(parser, "translateX")
    ty: Optional[str] = _xml_attr(parser, "translateY")
    rot: Optional[str] = _xml_attr(parser, "rotation")
    px: Optional[str] = _xml_attr(parser, "pivotX")
    py: Optional[str] = _xml_attr(parser, "pivotY")
    sx: Optional[str] = _xml_attr(parser, "scaleX")
    sy: Optional[str] = _xml_attr(parser, "scaleY")

    if tx or ty:
        transforms.append(f"translate({tx or 0},{ty or 0})")
    if rot:
        transforms.append(f"rotate({rot},{px or 0},{py or 0})")
    if sx or sy:
        transforms.append(f"scale({sx or 1},{sy or 1})")

    if not transforms:
        return ""
    return f' transform="{" ".join(transforms)}"'

def _vector_xml_to_svg(context, res_id: int) -> Optional[str]:
    # --- parse compiled android vectordrawable xml and emit svg markup ---
    from org.xmlpull.v1 import XmlPullParser

    xp = context.getResources().getXml(res_id)
    lines: List[str] = ['<?xml version="1.0" encoding="utf-8"?>']
    depth: int = 0
    is_vector: bool = False

    ev: int = xp.getEventType()
    while ev != XmlPullParser.END_DOCUMENT:
        if ev == XmlPullParser.START_TAG:
            tag: str = str(xp.getName())

            if tag == "vector":
                vw: str = _xml_attr(xp, "viewportWidth") or "24"
                vh: str = _xml_attr(xp, "viewportHeight") or "24"
                lines.append(
                    f'<svg xmlns="http://www.w3.org/2000/svg" '
                    f'viewBox="0 0 {vw} {vh}">'
                )
                depth = 1
                is_vector = True

            elif tag == "path" and is_vector:
                pad: str = "  " * depth
                attr_str: str = _build_path_attrs(xp)
                lines.append(f"{pad}<path {attr_str}/>")

            elif tag == "group" and is_vector:
                pad = "  " * depth
                transform: str = _build_group_transform(xp)
                lines.append(f"{pad}<g{transform}>")
                depth += 1

            elif tag == "clip-path" and is_vector:
                cpd: str = _xml_attr(xp, "pathData") or ""
                pad = "  " * depth
                clip_id: str = f"clip_{depth}"
                lines.append(
                    f'{pad}<defs><clipPath id="{clip_id}">'
                    f'<path d="{cpd}"/></clipPath></defs>'
                )

        elif ev == XmlPullParser.END_TAG:
            tag = str(xp.getName())
            if tag == "vector" and is_vector:
                lines.append("</svg>")
            elif tag == "group" and is_vector:
                depth = max(1, depth - 1)
                lines.append(f'{"  " * depth}</g>')

        ev = xp.next()

    xp.close()
    return "\n".join(lines) if is_vector else None

# ===========================================================================
#  png rasterization
# ===========================================================================

def _render_drawable_to_png(drawable, size: int, file_path: str) -> bool:
    # --- rasterize any android drawable to a png bitmap ---
    if drawable is None:
        return False
    try:
        bmp = Bitmap.createBitmap(size, size, Bitmap.Config.ARGB_8888)
        canvas = Canvas(bmp)
        drawable.setBounds(0, 0, size, size)
        drawable.draw(canvas)

        fos = FileOutputStream(file_path)
        bmp.compress(Bitmap.CompressFormat.PNG, 100, fos)
        fos.flush()
        fos.close()
        bmp.recycle()
        return True
    except Exception as e:
        logcat(f"PNG render failed: {e}")
        return False

# ===========================================================================
#  lottie json export from r.raw
# ===========================================================================

def _export_raw_resource(context, res_id: int, file_path: str) -> bool:
    # --- export r.raw resource bytes to a file ---
    try:
        from java.io import BufferedReader, InputStreamReader

        inp = context.getResources().openRawResource(res_id)
        reader = BufferedReader(InputStreamReader(inp, "UTF-8"))
        collected: List[str] = []
        line = reader.readLine()
        while line is not None:
            collected.append(str(line))
            line = reader.readLine()
        reader.close()

        with open(file_path, "w", encoding="utf-8") as f:
            f.write("\n".join(collected))
        return True
    except Exception as e:
        logcat(f"Raw export failed: {e}")
        return False

# ===========================================================================
#  helpers
# ===========================================================================

def _get_export_dir() -> str:
    # --- resolve export directory under downloads ---
    base: str = os.path.join(
        os.environ.get("EXTERNAL_STORAGE", "/sdcard"),
        "Download",
        _EXPORT_DIR_NAME,
    )
    os.makedirs(base, exist_ok=True)
    return base

# спизжено: паттерн получения оригинального drawable через ExteraResources из референса
def _get_drawable(activity, res_id: int):
    # --- get original drawable, preferring exteraresources if available ---
    try:
        if _HAS_EXTERA_UI:
            res = activity.getResources()
            if isinstance(res, ExteraResources):
                return res.getOriginalDrawable(res_id).mutate()
    except Exception:
        pass
    try:
        return ContextCompat.getDrawable(activity, res_id).mutate()
    except Exception:
        return None

# спизжено: логика фильтрации solar/remix/default — переписана из _load_all() референса
def _matches_type_filter(name: str, type_idx: int, icons_dict: Dict[str, int]) -> bool:
    # --- check if icon name passes the solar/remix/default type filter ---
    if type_idx == _TYPE_ALL:
        return True
    if type_idx == _TYPE_SOLAR:
        return "solar" in name
    if type_idx == _TYPE_REMIX:
        return "remix" in name
    if type_idx == _TYPE_DEFAULT:
        # спизжено: эта тройная проверка один-в-один из референса
        return (
            "solar" not in name
            and "remix" not in name
            and (
                f"{name}_remix" in icons_dict
                or f"{name}_solar" in icons_dict
            )
        )
    return True

