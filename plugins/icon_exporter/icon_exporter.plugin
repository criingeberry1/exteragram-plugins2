# спизжено: структура show_full_animation() из референса, добавлен экспорт JSON
def _show_animation_detail(activity, anim_name: str, res_id: int, on_dismiss_cb=None):
    # --- full-size lottie animation preview with play/pause and export ---
    try:
        builder = AlertDialog.Builder(activity)

        # спизжено: тот же layout skeleton
        frame_layout = FrameLayout(activity)
        builder.setView(frame_layout)

        scroll_view = ScrollView(activity)
        scroll_view.setFillViewport(True)
        frame_layout.addView(scroll_view, LayoutHelper.createFrame(-1, -1))

        linear = LinearLayout(activity)
        linear.setOrientation(LinearLayout.VERTICAL)
        linear.setGravity(Gravity.CENTER_HORIZONTAL)
        scroll_view.addView(
            linear, LayoutHelper.createFrame(-1, -2, Gravity.LEFT | Gravity.TOP)
        )

        # спизжено: RLottieImageView + setAutoRepeat + setAnimation из референса
        anim_view = RLottieImageView(activity)
        anim_view.setAutoRepeat(True)
        anim_view.setAnimation(res_id, 256, 256)
        anim_view.playAnimation()
        linear.addView(anim_view, LayoutHelper.createLinear(256, 256, Gravity.CENTER_HORIZONTAL))

        # спизжено: AltSeekbar с размером анимации из референса
        if _HAS_EXTERA_UI:
            def on_size_change(p):
                anim_view.setLayoutParams(LayoutHelper.createLinear(int(p), int(p)))
                anim_view.invalidate()

            seek = AltSeekbar(
                activity,
                gen(AltSeekbar.OnDrag, "run")(lambda p: on_size_change(p)),
                24, 256, S["anim_size"], S["min"], S["max"],
            )
            seek.setProgress(1)
            linear.addView(seek, LayoutHelper.createLinear(-1, -2))

        # спизжено: play/pause кнопка с динамической иконкой из референса
        play_btn = ButtonWithCounterView(activity, True, None)

        # спизжено: on_click с toggle + setText из референса
        def _update_play_text(playing: bool):
            ic_res = R.drawable.msg_round_pause_m if playing else R.drawable.msg_round_play_m
            sp = ColoredImageSpan(ContextCompat.getDrawable(activity, ic_res))
            sb = SpannableStringBuilder()
            sb.append("d ").setSpan(sp, 0, 1, 0)
            sb.append(S["pause"] if playing else S["play"])
            play_btn.setText(sb, False)

        def _toggle_play(_=None):
            if anim_view.isPlaying():
                anim_view.stopAnimation()
            else:
                anim_view.playAnimation()
            _update_play_text(anim_view.isPlaying())

        _update_play_text(True)
        play_btn.setOnClickListener(OnClickListener(_toggle_play))
        linear.addView(play_btn, LayoutHelper.createLinear(-1, 48, 0, 16, 28, 16, 4))

        # спизжено: кнопка копирования имени из референса
        copy_btn = ButtonWithCounterView(activity, False, None)
        span = ColoredImageSpan(ContextCompat.getDrawable(activity, R.drawable.msg_copy))
        ssb = SpannableStringBuilder()
        ssb.append("d ").setSpan(span, 0, 1, 0)
        ssb.append(anim_name)
        copy_btn.setText(ssb, False)
        copy_btn.setOnClickListener(OnClickListener(
            lambda _: (
                BulletinHelper.show_copied_to_clipboard()
                if AndroidUtilities.addToClipboard(anim_name)
                else None
            )
        ))
        linear.addView(copy_btn, LayoutHelper.createLinear(-1, 48, 0, 16, 4, 16, 4))

        # --- export json button (не спизжено) ---
        json_btn = ButtonWithCounterView(activity, True, None)
        json_ssb = SpannableStringBuilder()
        json_ssb.append(S["export_json"])
        json_btn.setText(json_ssb, False)
        json_btn.setOnClickListener(OnClickListener(
            lambda _: run_on_queue(
                lambda: _do_export_single_anim(activity, anim_name, res_id)
            )
        ))
        linear.addView(json_btn, LayoutHelper.createLinear(-1, 48, 0, 16, 4, 16, 16))

        # спизжено: setOnPreDismissListener + play_all callback из референса
        if on_dismiss_cb:
            builder.setOnPreDismissListener(OnDismissListener(lambda _: on_dismiss_cb()))

        dialog = builder.create()
        dialog.show()
    except Exception:
        logcat(traceback.format_exc())

def _do_export_single_anim(activity, name: str, res_id: int):
    # --- background worker: export one raw lottie animation ---
    try:
        out: str = _get_export_dir()
        path: str = os.path.join(out, f"{name}.json")
        if _export_raw_resource(activity, res_id, path):
            _n = name
            run_on_ui_thread(
                lambda: BulletinHelper.show_success(S["export_done"].format(f"{_n}.json"))
            )
            _maybe_show_egg()
        else:
            _n = name
            run_on_ui_thread(
                lambda: BulletinHelper.show_error(S["export_error"].format(_n))
            )
    except Exception:
        logcat(traceback.format_exc())
        _n = name
        run_on_ui_thread(
            lambda: BulletinHelper.show_error(S["export_error"].format(_n))
        )

# ===========================================================================
# спизжено: IconsSheet — переписан из класса IconsSheet референса
# ===========================================================================

class IconsSheet:
    def __init__(self, plugin, view_type: int):
        self.plugin = plugin
        self.view_type: int = view_type
        # спизжено: get_last_fragment() + getParentActivity() + getContext() из референса
        self.fragment = get_last_fragment()
        self.activity = self.fragment.getParentActivity()
        self.context = self.fragment.getContext()

        self._loaded: bool = False
        self._items: List[Any] = []
        self.count: int = 0
        self.filter: str = self.plugin.get_setting("icon_filter", "").strip().lower()
        # спизжено: type setting из референса
        self.type_idx: int = self.plugin.get_setting("icon_type", _TYPE_ALL)

        self.bottom_sheet = None
        self.builder = None

        # спизжено: run_on_queue(self._load_all) из референса
        run_on_queue(self._load_all)

    def _load_all(self):
        # спизжено: вся структура _load_all() из IconsSheet референса
        if self._loaded:
            return

        try:
            icons: Dict[str, int] = self.plugin.icons

            # спизжено: ExteraResources resolution из референса
            extera_res = None
            try:
                if _HAS_EXTERA_UI:
                    res = self.context.getResources()
                    if isinstance(res, ExteraResources):
                        extera_res = res
            except Exception:
                pass

            if self.view_type == 0:
                # спизжено: grid layout с вычислением row_size из референса
                width: int = self.context.getResources().getDisplayMetrics().widthPixels
                icon_w: int = 64 + dp(35)
                row_size: int = max(1, width // icon_w)
                frame = LayoutHelper.createFrame(
                    64, 64, 0, 0, 0,
                    int((width - icon_w * row_size) / row_size), 0,
                )
                # спизжено: ScaleType.CENTER из референса
                scale = ImageView.ScaleType.CENTER

                row_layout = LinearLayout(self.activity)
                k: int = 0

                for name, rid in icons.items():
                    if self.filter and self.filter not in name:
                        continue
                    if not _matches_type_filter(name, self.type_idx, icons):
                        continue

                    try:
                        # спизжено: AppCompatImageView + setBackground(createSelectorDrawable) из референса
                        icb = AppCompatImageView(self.activity)
                        icb.setScaleType(scale)
                        dr = (
                            extera_res.getOriginalDrawable(rid).mutate()
                            if extera_res
                            else ContextCompat.getDrawable(self.activity, rid).mutate()
                        )
                        icb.setImageDrawable(dr)
                        icb.setBackground(
                            Theme.createSelectorDrawable(
                                Theme.getColor(Theme.key_dialogButtonSelector), 1, dp(28)
                            )
                        )

                        _n = name
                        _r = rid
                        icb.setOnClickListener(OnClickListener(
                            lambda _, n=_n, r=_r: _show_icon_detail(self.activity, n, r)
                        ))
                        row_layout.addView(icb, frame)
                        k += 1
                        self.count += 1

                        # спизжено: row_size chunking из референса
                        if k == row_size:
                            self._items.append(UItem.asCustom(row_layout))
                            row_layout = LinearLayout(self.activity)
                            k = 0
                    except Exception:
                        logcat(f"Icon {name} load error: {traceback.format_exc()}")

                if k > 0:
                    self._items.append(UItem.asCustom(row_layout))
            else:
                # спизжено: list mode с UItem.asButton из референса
                for name, rid in icons.items():
                    if self.filter and self.filter not in name:
                        continue
                    if not _matches_type_filter(name, self.type_idx, icons):
                        continue

                    try:
                        dr = (
                            extera_res.getOriginalDrawable(rid).mutate()
                            if extera_res
                            else ContextCompat.getDrawable(self.activity, rid).mutate()
                        )
                        self._items.append(UItem.asButton(0, dr, name))
                        self.count += 1
                    except Exception:
                        logcat(f"Icon {name} load error: {traceback.format_exc()}")

        except Exception:
            logcat(traceback.format_exc())

        self._loaded = True
        # спизжено: run_on_ui_thread + adapter.update(True) из референса
        run_on_ui_thread(lambda: self.list_view.adapter.update(True))

    # спизжено: fill_items() с setTitle из референса
    def fill_items(self, items, adapter):
        # --- provide items to universalrecyclerview adapter ---
        try:
            title: str = S["icons"]
            if self.filter:
                title += " • " + self.filter
            t_name = _TYPE_NAMES.get(self.type_idx)
            if t_name:
                title += " • " + t_name

            if not self._loaded:
                items.add(UItem.asHeader(S["loading"]))
            else:
                for item in self._items:
                    items.add(item)
                title += f" ({self.count})"

            target = self.bottom_sheet if self.bottom_sheet else self.builder
            if target:
                target.setTitle(title, True)
        except Exception:
            items.add(UItem.asShadow(traceback.format_exc()))

    # спизжено: on_click dispatch из референса
    def on_click(self, item, *_):
        # --- handle list item click ---
        if self.view_type == 1 and item.text:
            name: str = str(item.text)
            rid: int = self.plugin.icons.get(name, 0)
            if rid:
                _show_icon_detail(self.activity, name, rid)

    # спизжено: show() с BottomSheet.Builder + UniversalRecyclerView из референса
    def show(self):
        # --- create and present the bottom sheet ---
        self.builder = BottomSheet.Builder(self.activity)
        self.builder.setApplyTopPadding(False)
        self.builder.setApplyBottomPadding(False)

        content = FrameLayout(self.activity)
        self.builder.setCustomView(content)
        content.setBackgroundColor(Theme.getColor(Theme.key_windowBackgroundGray))

        self.list_view = UniversalRecyclerView(
            self.fragment,
            Callback2(self.fill_items),
            Callback5(self.on_click),
            None,
        )
        content.addView(self.list_view, LayoutHelper.createFrame(-1, 700))

        self.bottom_sheet = self.builder.show()
        self.bottom_sheet.setCanDismissWithSwipe(False)

# ===========================================================================
# спизжено: AnimationsSheet — переписан из класса AnimationSheet референса
# ===========================================================================

class AnimationsSheet:
    def __init__(self, plugin, view_type: int):
        self.plugin = plugin
        self.view_type: int = view_type
        self.fragment = get_last_fragment()
        self.activity = self.fragment.getParentActivity()
        self.context = self.fragment.getContext()

        self._loaded: bool = False
        self._items: List[Any] = []
        # спизжено: self.all (список анимаций для stop/play) из референса
        self._anim_views: List[Any] = []
        self.count: int = 0
        self.filter: str = self.plugin.get_setting("anim_filter", "").strip().lower()

        self.bottom_sheet = None
        self.builder = None

        run_on_queue(self._load_all)

    def _load_all(self):
        # спизжено: вся структура из AnimationSheet._load_all() референса
        if self._loaded:
            return

        try:
            anims: Dict[str, int] = self.plugin.animations
            scale = ImageView.ScaleType.CENTER

            if self.view_type == 0:
                # спизжено: grid layout для анимаций из референса
                width: int = self.context.getResources().getDisplayMetrics().widthPixels
                icon_w: int = dp(56)
                row_size: int = max(1, width // icon_w - 1)
                frame = LayoutHelper.createFrame(
                    48, 48, 0, 0, 0,
                    int((width - icon_w * row_size) / row_size), 0,
                )

                row_layout = LinearLayout(self.activity)
                k: int = 0

                for name, rid in anims.items():
                    if self.filter and self.filter not in name:
                        continue

                    try:
                        # спизжено: RLottieImageView + setAutoRepeat + playAnimation из референса
                        icb = RLottieImageView(self.activity)
                        icb.setScaleType(scale)
                        icb.setAutoRepeat(True)
                        icb.setAnimation(rid, 46, 46)
                        icb.playAnimation()
                        icb.setBackground(
                            Theme.createSelectorDrawable(
                                Theme.getColor(Theme.key_dialogButtonSelector), 1, dp(28)
                            )
                        )

                        _n = name
                        _r = rid
                        icb.setOnClickListener(OnClickListener(
                            lambda _, n=_n, r=_r: self._open_anim(n, r)
                        ))
                        row_layout.addView(icb, frame)
                        self._anim_views.append(icb)
                        k += 1
                        self.count += 1

                        if k == row_size:
                            self._items.append(UItem.asCustom(row_layout))
                            row_layout = LinearLayout(self.activity)
                            k = 0
                    except Exception:
                        logcat(f"Anim {name} load error: {traceback.format_exc()}")

                if k > 0:
                    self._items.append(UItem.asCustom(row_layout))
            else:
                # спизжено: list mode с LinearLayout + TextView из референса
                text_color: int = Theme.getColor(Theme.key_windowBackgroundWhiteBlackText)
                frame = LayoutHelper.createFrame(48, 48, 0, 8, 4, 0, 4)
                frame2 = LayoutHelper.createFrame(-2, -2, Gravity.CENTER_VERTICAL, 12, 0, 0, 0)

                for name, rid in anims.items():
                    if self.filter and self.filter not in name:
                        continue

                    try:
                        layout = LinearLayout(self.activity)

                        icb = RLottieImageView(self.activity)
                        icb.setScaleType(scale)
                        icb.setAutoRepeat(True)
                        icb.setAnimation(rid, 46, 46)
                        icb.playAnimation()
                        self._anim_views.append(icb)
                        layout.addView(icb, frame)

                        tv = TextView(self.activity)
                        tv.setTextColor(text_color)
                        tv.setTextSize(TypedValue.COMPLEX_UNIT_DIP, 18)
                        tv.setGravity(Gravity.CENTER_VERTICAL)
                        tv.setText(name)
                        layout.addView(tv, frame2)

                        # спизжено: item.object2 = name из референса
                        item = UItem.asCustom(layout)
                        item.object2 = name
                        self._items.append(item)
                        self.count += 1
                    except Exception:
                        logcat(f"Anim {name} load error: {traceback.format_exc()}")

        except Exception:
            logcat(traceback.format_exc())

        self._loaded = True
        run_on_ui_thread(lambda: self.list_view.adapter.update(True))

    # спизжено: open_animation() + stopAnimation/playAnimation для всех из референса
    def _open_anim(self, name: str, rid: int):
        # --- stop all sheet animations, open detail, resume on dismiss ---
        for v in self._anim_views:
            try:
                v.stopAnimation()
            except Exception:
                pass

        def _resume():
            for v in self._anim_views:
                try:
                    v.playAnimation()
                except Exception:
                    pass

        _show_animation_detail(self.activity, name, rid, on_dismiss_cb=_resume)

    def fill_items(self, items, adapter):
        # --- provide items to universalrecyclerview adapter ---
        try:
            title: str = S["animations"]
            if self.filter:
                title += " • " + self.filter

            if not self._loaded:
                items.add(UItem.asHeader(S["loading"]))
            else:
                for item in self._items:
                    items.add(item)
                title += f" ({self.count})"

            target = self.bottom_sheet if self.bottom_sheet else self.builder
            if target:
                target.setTitle(title, True)
        except Exception:
            items.add(UItem.asShadow(traceback.format_exc()))

    def on_click(self, item, *_):
        # --- handle list item click ---
        if self.view_type == 1 and item.object2:
            name: str = str(item.object2)
            rid: int = self.plugin.animations.get(name, 0)
            if rid:
                self._open_anim(name, rid)

    # спизжено: show() — тот же BottomSheet.Builder паттерн из референса
    def show(self):
        # --- create and present the bottom sheet ---
        self.builder = BottomSheet.Builder(self.activity)
        self.builder.setApplyTopPadding(False)
        self.builder.setApplyBottomPadding(False)

        content = FrameLayout(self.activity)
        self.builder.setCustomView(content)
        content.setBackgroundColor(Theme.getColor(Theme.key_windowBackgroundGray))

        self.list_view = UniversalRecyclerView(
            self.fragment,
            Callback2(self.fill_items),
            Callback5(self.on_click),
            None,
        )
        content.addView(self.list_view, LayoutHelper.createFrame(-1, 700))

        self.bottom_sheet = self.builder.show()
        self.bottom_sheet.setCanDismissWithSwipe(False)

# ===========================================================================
#  main plugin class
# ===========================================================================

class IconExporterPlugin(BasePlugin):

    def __init__(self):
        super().__init__()
        self.icons: Dict[str, int] = {}
        self.animations: Dict[str, int] = {}

    # спизжено: safe_getattr из референса
    def _safe_getattr(self, obj, attr, default=None):
        # --- safely read attribute from java r-class without crashing ---
        try:
            return getattr(obj, attr)
        except Exception:
            return default

    def on_plugin_load(self) -> None:
        # спизжено: enumeration через dir(R.drawable) + walrus operator из референса
        allowed_chars: str = "abcdefghijklmnopqrstuvwxyz0123456789_"

        self.icons = {
            name: attr
            for name in dir(R.drawable)
            if (
                all(c in allowed_chars for c in name)
                and not name.startswith("_")
                and (attr := self._safe_getattr(R.drawable, name))
            )
        }

        self.animations = {
            name: attr
            for name in dir(R.raw)
            if (
                all(c in allowed_chars for c in name)
                and not name.startswith("_")
                and (attr := self._safe_getattr(R.raw, name))
            )
        }

        self.log(
            f"Loaded: {len(self.icons)} drawable, {len(self.animations)} raw"
        )

    def on_plugin_unload(self) -> None:
        # --- release cached references ---
        self.icons.clear()
        self.animations.clear()

    # --- batch export workers (не спизжено, полностью моё) ---

    def _batch_export_drawables(self):
        # --- export all matching drawable icons in selected format ---
        frag = get_last_fragment()
        if not frag:
            return
        activity = frag.getParentActivity()
        if not activity:
            return

        query: str = self.get_setting("icon_filter", "").strip().lower()
        fmt: int = self.get_setting("export_format", _FMT_SVG)
        pidx: int = self.get_setting("png_res", 4)
        psz: int = _PNG_SIZES[pidx] if 0 <= pidx < len(_PNG_SIZES) else 512
        type_idx: int = self.get_setting("icon_type", _TYPE_ALL)

        matched: List[Tuple[str, int]] = []
        for name, rid in self.icons.items():
            if query and query not in name:
                continue
            if not _matches_type_filter(name, type_idx, self.icons):
                continue
            matched.append((name, rid))

        if not matched:
            BulletinHelper.show_error("Совпадений не найдено")
            return

        if len(matched) > 1000:
            BulletinHelper.show_error(f"Слишком много ({len(matched)}), уточните фильтр")
            return

        total: int = len(matched)
        BulletinHelper.show_info(f"Экспорт {total} иконок...")

        def _worker():
            out: str = _get_export_dir()
            ok: int = 0
            fail: int = 0

            for name, rid in matched:
                try:
                    if fmt == _FMT_SVG:
                        svg: Optional[str] = None
                        try:
                            svg = _vector_xml_to_svg(activity, rid)
                        except Exception:
                            pass

                        if svg:
                            path: str = os.path.join(out, f"{name}.svg")
                            with open(path, "w", encoding="utf-8") as f:
                                f.write(svg)
                            ok += 1
                        else:
                            # --- non-vector drawable, fallback to png ---
                            path = os.path.join(out, f"{name}_{psz}px.png")
                            dr = _get_drawable(activity, rid)
                            if _render_drawable_to_png(dr, psz, path):
                                ok += 1
                            else:
                                fail += 1
                    elif fmt == _FMT_PNG:
                        path = os.path.join(out, f"{name}_{psz}px.png")
                        dr = _get_drawable(activity, rid)
                        if _render_drawable_to_png(dr, psz, path):
                            ok += 1
                        else:
                            fail += 1
                except Exception:
                    logcat(f"Batch error [{name}]: {traceback.format_exc()}")
                    fail += 1

            _ok, _fail, _total = ok, fail, total
            err_suffix: str = f" (ошибок: {_fail})" if _fail > 0 else ""
            run_on_ui_thread(
                lambda: BulletinHelper.show_success(
                    S["batch_done"].format(ok=_ok, total=_total) + err_suffix
                )
            )
            _maybe_show_egg()

        run_on_queue(_worker)

    def _batch_export_animations(self):
        # --- export all matching raw lottie animations ---
        frag = get_last_fragment()
        if not frag:
            return
        activity = frag.getParentActivity()
        if not activity:
            return

        query: str = self.get_setting("anim_filter", "").strip().lower()

        matched: List[Tuple[str, int]] = [
            (name, rid) for name, rid in self.animations.items()
            if not query or query in name
        ]

        if not matched:
            BulletinHelper.show_error("Совпадений не найдено")
            return

        total: int = len(matched)
        BulletinHelper.show_info(f"Экспорт {total} анимаций...")

        def _worker():
            out: str = _get_export_dir()
            ok: int = 0
            fail: int = 0

            for name, rid in matched:
                try:
                    path: str = os.path.join(out, f"{name}.json")
                    if _export_raw_resource(activity, rid, path):
                        ok += 1
                    else:
                        fail += 1
                except Exception:
                    logcat(f"Batch anim error [{name}]: {traceback.format_exc()}")
                    fail += 1

            _ok, _fail, _total = ok, fail, total
            err_suffix: str = f" (ошибок: {_fail})" if _fail > 0 else ""
            run_on_ui_thread(
                lambda: BulletinHelper.show_success(
                    S["batch_done"].format(ok=_ok, total=_total) + err_suffix
                )
            )
            _maybe_show_egg()

        run_on_queue(_worker)

    # спизжено: export_to_file() из референса, слегка переписана
    def _export_names_list(self):
        # --- save complete icon and animation name list to a text file ---
        try:
            base: str = os.path.join(
                os.environ.get("EXTERNAL_STORAGE", "/sdcard"), "Download"
            )
            os.makedirs(base, exist_ok=True)
            path: str = os.path.join(base, "All_Telegram_Icons_List.txt")

            with open(path, "w", encoding="utf-8") as f:
                f.write("=== TELEGRAM ICONS ===\n")
                f.write(f"Всего R.drawable: {len(self.icons)}\n")
                f.write(f"Всего R.raw: {len(self.animations)}\n\n")
                for name in sorted(self.icons.keys()):
                    f.write(f"{name}\n")
                f.write("\n")
                for name in sorted(self.animations.keys()):
                    f.write(f"{name}\n")

            BulletinHelper.show_success(S["export_done"].format(path))
        except Exception as e:
            self.log(f"List export error: {e}")
            BulletinHelper.show_error(S["export_error"].format(str(e)[:80]))

    # --- settings ui ---

    # спизжено: структура create_settings() из референса, расширена экспорт-секцией
    def create_settings(self) -> list:
        # --- build the plugin settings screen ---
        return [
            Header(text=S["icons"]),
            Input(
                key="icon_filter",
                text=S["search"],
                icon="msg_search",
                default="",
            ),
            # спизжено: Selector с типами Solar/Remix/Default из референса
            Selector(
                key="icon_type",
                text=S["type"],
                default=_TYPE_ALL,
                items=[S["all"], "Solar", "Remix", "Default"],
                icon="menu_select_quote_solar",
            ),
            # спизжено: кнопки Плитка/Список из референса
            Text(
                text=S["grid"],
                accent=True,
                on_click=lambda _: IconsSheet(self, 0).show(),
                icon="input_bot2_solar",
            ),
            Text(
                text=S["list"],
                accent=True,
                on_click=lambda _: IconsSheet(self, 1).show(),
                icon="msg_reorder",
            ),
            Selector(
                key="export_format",
                text=S["format"],
                default=_FMT_SVG,
                items=["SVG (вектор)", "PNG (растр)"],
                icon="msg_photo_settings",
            ),
            Selector(
                key="png_res",
                text=S["png_res"],
                default=4,
                items=_PNG_LABELS,
                icon="msg_zoomin",
            ),
            Text(
                text=S["export_all_matched"] + " (drawable)",
                accent=True,
                on_click=lambda _: self._batch_export_drawables(),
                icon="msg_download",
            ),
            Divider(
                text="Некоторые фичи были спизжены из All Telegram Icons "
                     "от @mur_live (форкер) и DevSettingIcons от @CactusPlugins (автор)"
            ),

            Header(text=S["animations"]),
            Input(
                key="anim_filter",
                text=S["search"],
                icon="msg_search",
                default="",
            ),
            Text(
                text=S["grid"],
                accent=True,
                on_click=lambda _: AnimationsSheet(self, 0).show(),
                icon="input_bot2_solar",
            ),
            Text(
                text=S["list"],
                accent=True,
                on_click=lambda _: AnimationsSheet(self, 1).show(),
                icon="msg_reorder",
            ),
            Text(
                text=S["export_all_matched"] + " (Lottie JSON)",
                accent=True,
                on_click=lambda _: self._batch_export_animations(),
                icon="msg_download",
            ),
            Divider(
                text="🌵🌵🌵 github.com/Den4ikSuperOstryyPer4ik/CactusPlugins 🌵🌵🌵"
            ),

            Header(text=S["other"]),
            Text(
                text=S["export_list"],
                accent=True,
                on_click=lambda _: self._export_names_list(),
                icon="msg_log_solar",
            ),
            Divider(text=f"Экспорт → Download/{_EXPORT_DIR_NAME}"),
